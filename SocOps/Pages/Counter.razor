@page "/counter"

<PageTitle>Counter</PageTitle>

<div class="counter-page">
    <h1>Counter</h1>
    <p>Current count: @currentCount</p>
    <button class="primary-btn" @onclick="IncrementCount">Increment</button>
</div>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
